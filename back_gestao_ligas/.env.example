# ── Configurações de Segurança ────────────────────────────────────────────────
# Gere valores aleatórios longos para produção.
# Exemplo Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-um-valor-seguro-e-longo
JWT_SECRET_KEY=troque-por-outro-valor-seguro-e-longo

# ── Banco de Dados ────────────────────────────────────────────────────────────
# Produção (PostgreSQL):
SQLALCHEMY_DATABASE_URI=postgresql://usuario:senha@localhost:5432/gestao_ligas

# Desenvolvimento local (SQLite — sem instalar Postgres):
# SQLALCHEMY_DATABASE_URI=sqlite:///gestao_ligas.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Para local acadêmico, pode manter '*' durante desenvolvimento.
# Em produção, informe lista separada por vírgulas (sem espaços):
# CORS_ORIGINS=http://localhost:3000,https://seu-dominio.com
CORS_ORIGINS=*

# ── Bootstrap do Primeiro Administrador ─────────────────────────────────────
# Se BOOTSTRAP_ADMIN_ENABLED=true e não houver nenhum ADMIN no banco,
# a API cria (ou promove por e-mail) a conta abaixo no primeiro start.
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_NAME=Administrador Inicial
BOOTSTRAP_ADMIN_EMAIL=admin@ligas.local
BOOTSTRAP_ADMIN_PASSWORD=admin123
